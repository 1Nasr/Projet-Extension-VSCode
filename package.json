{
  "name": "markdown-visualizer",
  "displayName": "Markdown Visualizer",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "activationEvents": [
    "onView:visualizerView",
    "onCommand:markdown-visualizer.compilePanel"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "visualizerContainer",
          "title": "Visualizer",
          "icon": "$(preview)"
        }
      ]
    },
    "views": {
      "visualizerContainer": [
        {
          "id": "visualizerView",
          "name": "Visualizer"
        }
      ]
    },
    "commands": [
      {
        "command": "latex-visualizer.compilePanel",
        "title": "compilePanel LaTeX and Preview PDF"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1"
  },
  "dependencies": {
    "katex": "^0.16.27",
    "markdown-it": "^14.1.0",
    "markdown-it-katex": "^2.0.3",
    "puppeteer": "^24.33.0"
  }
}
