{
  "name": "markdown-visualizer",
  "displayName": "Markdown Visualizer",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.33714"
  },
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Markdown Visualizer",
      "properties": {
        "visualizer.preview.mermaidTheme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "dark",
            "forest",
            "neutral",
            "base"
          ],
          "description": "Theme Mermaid utilise dans le preview."
        },
        "visualizer.preview.updateMode": {
          "type": "string",
          "default": "onType",
          "enum": [
            "onType",
            "onSave"
          ],
          "description": "Frequence de mise a jour du preview Markdown."
        },
        "visualizer.preview.fontSize": {
          "type": "number",
          "default": 16,
          "minimum": 10,
          "maximum": 40,
          "description": "Taille de police du preview en pixels."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "visualizerContainer",
          "title": "Templates",
          "icon": "$(preview)"
        }
      ]
    },
    "views": {
      "visualizerContainer": [
        {
          "id": "visualizerView",
          "name": "Templates",
          "icon": "$(symbol-class)"
        }
      ]
    },
    "commands": [
      {
        "command": "visualizer.markdownPreview",
        "title": "markdown Preview",
        "icon": "$(preview)"
      },
      {
        "command": "visualizer.openPreviewSettings",
        "title": "Ouvrir les reglages du preview",
        "icon": "$(gear)"
      },
      {
        "command": "visualizer.copyTemplate",
        "title": "Copier le template",
        "icon": "$(copy)"
      },
      {
        "command": "visualizer.createTemplate",
        "title": "Creer un nouveau template",
        "icon": "$(add)"
      },
      {
        "command": "visualizer.editTemplate",
        "title": "Editer le template",
        "icon": "$(edit)"
      },
      {
        "command": "visualizer.deleteTemplate",
        "title": "Supprimer le template",
        "icon": "$(trash)"
      },
      {
        "command": "visualizer.addCategory",
        "title": "Ajouter une categorie",
        "icon": "$(new-folder)"
      },
      {
        "command": "visualizer.deleteCategory",
        "title": "Supprimer la categorie",
        "icon": "$(folder-active)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "visualizer.addCategory",
          "when": "view == visualizerView",
          "group": "navigation"
        },
        {
          "command": "visualizer.createTemplate",
          "when": "view == visualizerView",
          "group": "navigation"
        },
        {
          "command": "visualizer.openPreviewSettings",
          "when": "view == visualizerView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "visualizer.editTemplate",
          "when": "viewItem == template",
          "group": "inline@1"
        },
        {
          "command": "visualizer.deleteTemplate",
          "when": "viewItem == template",
          "group": "inline@2"
        },
        {
          "command": "visualizer.deleteCategory",
          "when": "viewItem == category",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1"
  },
  "dependencies": {
    "@marp-team/marp-core": "^4.2.0",
    "@wekanteam/markdown-it-mermaid": "^0.6.4",
    "katex": "^0.16.27",
    "markdown-it": "^14.1.0",
    "markdown-it-katex": "^2.0.3",
    "marked": "^17.0.1",
    "mermaid": "^11.12.2",
    "puppeteer": "^24.33.0",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-mermaid": "^0.2.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  }
}
